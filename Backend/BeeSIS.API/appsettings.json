{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "GitHub": {
    "Owner": "vtniscoding",
    "Repository": "beeSIS",
    "RawContentUrl": "https://raw.githubusercontent.com/vtniscoding/beeSIS/main/Data"
  },
  "Jwt": {
    "SecretKey": "BeeSIS-SuperSecret-JWT-Key-Min32Chars-2024!",
    "Issuer": "BeeSIS-API",
    "Audience": "BeeSIS-Users",
    "ExpirationMinutes": "60"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/beesis-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  }
}
